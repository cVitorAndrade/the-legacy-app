{
  "name": "@repo/database",
  "version": "1.0.0",
  "private": true,
  "description": "Prisma database package",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "push": "dotenv -e ../../.env -- prisma db push",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "studio": "dotenv -e ../../.env -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "dotenv-cli": "^7.4.2",
    "prisma": "^7.7.0",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@10.19.0"
}
